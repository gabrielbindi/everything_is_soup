command echo -e "\033[0m"
command echo -e "\033[1;33mWelcome to the Soup Kitchen!\033[0m"
command echo -e "\033[1;33mYour terminal is now configured for cooking some delicious soups.\033[0m"
command echo -e "\033[1;33mType \033[32m'recipe'\033[1;33m for commands or \033[32m'spill'\033[1;33m to exit.\033[0m\n"

PS1="\n\[\033[1;33m\]soupchef\[\033[0;31m\]\u\[\033[1;33m\]_cooking_\033[0;31m\]\w\[\033[0m\]> "


alias stir='builtin cd'
alias menu='command ls -la --color=auto'
alias cook='command mkdir -p'
alias boil='command touch'
alias taste='command cat'
alias spill='command exit'
alias drop='command rm -rf'
alias nutrient='command du -cks * | command sort -rn | command head -11'
alias eat='command clear'
alias surf='command echo'
alias reheat='command reboot'
alias susu='command sudo'
alias cooldown='command systemctl poweroff'

recipe() {
    command echo -e "\033[1;33mAvailable Ingredients:\033[0m"
    command echo "  stir  [directory] -> change directory      | menu     -> show files"
    command echo "  cook  [name]      -> make directory        | boil     -> create file"
    command echo "  taste [file]      -> show file contents    | spill    -> exit"
    command echo "  drop  [file/dir]  -> delete file/directory | nutrient -> show file size"
    command echo "  eat   [clear]     -> clears Terminal       | surf     -> echo"
    command echo "  susu  [chef]      -> super user            | reheat   -> reboot"
    command echo "                                             | cooldown -> shutdown"
}

mkdir() { command echo "You spilled your soup!: Did you mean 'cook'?"; }
touch() { command echo "You spilled your soup!: Did you mean 'boil'?"; }
cd() { command echo "You spilled your soup!: Did you mean 'stir'?"; }
ls() { command echo "You spilled your soup!: Did you mean 'menu'?"; }
cat() { command echo "You spilled your soup!: Did you mean 'taste'?"; }
rm() { command echo "You spilled your soup!: Did you mean 'drop'?"; }
exit() { command echo "You spilled your soup!: Did you mean 'spill'?"; }
du() { command echo "You spilled your soup!: Did you mean 'nutrient'?";}
clear() { command echo "You spilled your soup!: Did you mean 'eat'?";}
echo() { command echo "You spilled your soup!: Did you mean 'surf'?";}
reboot() { command echo "You spilled your soup!: Did you mean 'reheat'?";}
sudo() { command echo "You spilled your soup!: Did you mean 'susu'?";}
shutdown() { command echo "You spilled your soup!: Did you mean 'cooldown'?";}

SOUP_SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOUP_SOURCE" ]; do
  SOUP_CORE_DIR="$(command cd -P "$(dirname "$SOUP_SOURCE")" && pwd)"
  SOUP_SOURCE="$(readlink "$SOUP_SOURCE")"
  [[ $SOUP_SOURCE != /* ]] && SOUP_SOURCE="$SOUP_CORE_DIR/$SOUP_SOURCE"
done
SOUP_CORE_DIR="$(command cd -P "$(dirname "$SOUP_SOURCE")" && pwd)"

if [ -f "$SOUP_CORE_DIR/plugins/lazygit.sh" ]; then
    source "$SOUP_CORE_DIR/plugins/lazygit.sh"
fi

if [ -f "$SOUP_CORE_DIR/plugins/lazydocker.sh" ]; then
    source "$SOUP_CORE_DIR/plugins/lazydocker.sh"
fi