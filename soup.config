echo -e "\033[0m"
echo -e "\033[1;33mWelcome to the Soup Kitchen!\033[0m"
echo -e "\033[1;33mYour terminal is now configured for cooking some delicious soups.\033[0m"
echo -e "\033[1;33mType \033[32m'recipe'\033[1;33m for commands or \033[32m'leave'\033[1;33m to exit.\033[0m\n"

PS1="\n\[\033[1;33m\]soupchef\\\[\033[0;31m\]\u\[\033[1;33m\]\\cooking\\\w\[\033[0m\]> "


alias stir='cd'
alias menu='ls -la --color=auto'
alias cook='mkdir -p'
alias boil='touch'
alias taste='cat'
alias leave='exit'
alias spill='rm -rf'

recipe() {
    echo -e "\033[1;33mAvailable Ingredients:\033[0m"
    echo "  stir  [directory] -> change directory      | menu  -> show files"
    echo "  cook  [name]      -> make directory        | boil  -> create file"
    echo "  taste [file]      -> show file contents    | leave -> exit"
}

mkdir() { echo "You spilled your soup!: Did you mean 'cook'?"; }
touch() { echo "You spilled your soup!: Did you mean 'boil'?"; }